<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_consignee_warehouse_wizard_form" model="ir.ui.view">
        <field name="name">consignee.warehouse.wizard.form</field>
        <field name="model">consignee.warehouse.wizard</field>
        <field name="arch" type="xml">
            <form string="Onboard Consignee Warehouse">
                <group>
                    <field name="partner_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="warehouse_code"/>
                    <field name="warehouse_name"/>
                </group>
                <footer>
                    <button string="Create Warehouse" type="object"
                            name="action_create_warehouse" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_consignee_warehouse_wizard" model="ir.actions.act_window">
        <field name="name">Onboard Consignee Warehouse</field>
        <field name="res_model">consignee.warehouse.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_consignee_warehouse_wizard"
              name="Onboard Consignee Warehouse"
              parent="stock.menu_warehouse_config"
              action="action_consignee_warehouse_wizard"
              sequence="50"/>

</odoo>
