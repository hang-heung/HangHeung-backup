<odoo>
    <data>

        <record id="view_stock_picking_form_inherit" model="ir.ui.view">
            <field name="name">Stock Picking Form Inherit</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='do_print_picking']" position="before">

                    <field name="has_dropship_origin" invisible="1"/>
                    <field name="dropship_validated" invisible="1"/>
                    <button name="button_dropship_validate" invisible="state not in ('done') or not has_dropship_origin or dropship_validated" string="Validate Dropship" type="object" class="oe_highlight" groups="stock.group_stock_user" data-hotkey="v"/>

                </xpath>

                <xpath expr="//field[@name='origin']" position="after">
                    <field name="full_origin_chain" readonly="1"/>
                </xpath>

                <xpath expr="//field[@name='move_ids_without_package']/list" position="inside">
                    <control>
                        <create name="add_product_control" string="Add a Product"/>
                        <button name="action_add_from_catalog" type="object" string="Catalog"
                                class="px-4 btn-link"
                                context="{'order_id': parent.id}"
                                invisible="parent.picking_type_code != 'internal'"/>
                    </control>
                </xpath>

                <xpath expr="//field[@name='move_ids_without_package']" position="before">
                    <button name="action_set_qty_to_demand"
                            string="一鍵輸入收貨量"
                            type="object"
                            class="btn-secondary mb-2"
                            invisible="state in ('done','cancel') or picking_type_code != 'incoming' or company_id != 1"/>
                </xpath>

            </field>
        </record>
    </data>


    <record id="view_stock_picking_tree_inherit" model="ir.ui.view">
        <field name="name">Stock Picking Tree Inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="reason_code" invisible="picking_type_code != 'internal'"/>
            </xpath>

        </field>
    </record>
</odoo>