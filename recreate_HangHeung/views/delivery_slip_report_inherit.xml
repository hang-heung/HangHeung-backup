<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data inherit_id="stock.report_delivery_document">

        <xpath expr="//div[@class='page']/h2" position="replace">
            <h2 style="font-size:24pt; margin-bottom:8px;">
                Delivery Note <span t-field="o.name"/>
            </h2>
        </xpath>
        <xpath expr="//div[@class='page']/div[2]" position="replace"/>
        <xpath expr="//div[@class='page']/div[3]" position="replace"/>
        <xpath expr="//t[@t-set='address']" position="replace"/>
        <xpath expr="//table[@name='stock_move_table']" position="before">
            <div style="margin-bottom: 6px;">
                <div style="display: inline-block; margin-right: 275px; width: 250px; vertical-align: top;">
                    <div class="col-7" name="div_incoming_address">
                        <t t-set="show_partner" t-value="False"/>
                        <div name="vendor_address" t-if="o.picking_type_id.code=='incoming' and partner">
                            <span>
                                <strong>Vendor Address:</strong>
                            </span>
                            <t t-set="show_partner" t-value="True"/>
                        </div>
                        <div name="customer_address" t-if="o.picking_type_id.code=='outgoing' and partner and partner != partner.commercial_partner_id">
                            <span>
                                <strong>Customer Address:</strong>
                            </span>
                            <t t-set="show_partner" t-value="True"/>
                        </div>
                        <div t-if="show_partner" name="partner_header">
                            <div t-field="partner.commercial_partner_id" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;, &quot;phone&quot;, &quot;vat&quot;], &quot;no_marker&quot;: True}"/>
                        </div>
                    </div>
                </div>

                <div style="display: inline-block; width: 300px; vertical-align: top;">
                    <div name="outgoing_delivery_address" t-if="o.should_print_delivery_address()">
                        <span>
                            <strong>Delivery Address:</strong>
                        </span>
                        <t t-set="_del_p" t-value="o.move_ids[0].partner_id or o.partner_id"/>
                        <div t-if="_del_p.commercial_partner_id.name == 'HH'"
                             t-out="_del_p"
                             t-options='{"widget": "contact", "fields": ["name", "phone"], "no_marker": True}'/>
                        <div t-else=""
                             t-out="_del_p"
                             t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </div>
                    <div name="outgoing_warehouse_address" t-elif="o.picking_type_id.code != 'internal' and o.picking_type_id.warehouse_id.partner_id">
                        <span>
                            <strong>Warehouse Address:</strong>
                        </span>
                        <div t-field="o.picking_type_id.warehouse_id.partner_id" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;, &quot;phone&quot;], &quot;no_marker&quot;: True}"/>
                    </div>
                </div>
            </div>

            <!-- Set current report name for external_layout_standard-->
            <t t-set="current_report_name" t-value="'stock.report_deliveryslip'"/>

            <div class="report-wrapping-flexbox clearfix row" style="margin-top: 4px; margin-bottom: 8px;">
                <div t-if="o.origin" style="display: inline-block; width: 30%; margin-right: 15px;" name="div_origin">
                    <strong style="color: #AF8489">Order:</strong>
                    <p t-field="o.origin" class="m-0">S0001</p>
                </div>
                <div t-if="o.state" style="display: inline-block; width: 30%;" name="div_sched_date">
                    <strong style="color: #AF8489">Shipping Date:</strong>
                    <p t-field="o.scheduled_date" class="m-0"/>
                </div>
                <div t-if="o.origin" style="display: inline-block; width: 30%;" name="div_sched_date">
                    <strong style="color: #AF8489">Customer Reference:</strong>
                    <t t-set="source" t-value="o.full_origin_chain or o.origin or ''"/>
                    <t t-set="chain_last" t-value="source.split('-')[-1].strip()"/>
                    <t t-set="po_ref" t-value="o.intercompany_po_ref or ''"/>
                    <t t-set="receipt_ref" t-value="o.intercompany_receipt_name or ''"/>
                    <p class="m-0">
                        <t t-if="po_ref and receipt_ref">採購單<t t-esc="po_ref"/><br/>收貨單<t t-esc="receipt_ref"/></t><t t-elif="chain_last"><t t-esc="chain_last"/></t>
                    </p>
                </div>
            </div>
            <div t-if="o.is_wedding_order or o.is_b2b_order" style="margin: 4px 0 8px 0; padding: 4px 6px; border: 1px solid #AF8489; background: #FFF8F8; font-size: 12pt;">
                <strong style="color: #AF8489">訂單類型 / Order Type:</strong>
                <span t-if="o.is_wedding_order" style="margin-left: 8px; padding: 1px 6px; background: #C8102E; color: #fff; border-radius: 3px; font-weight: bold;">嫁囍單</span>
                <span t-if="o.is_b2b_order" style="margin-left: 8px; padding: 1px 6px; background: #1F4E79; color: #fff; border-radius: 3px; font-weight: bold;">B2B單</span>
            </div>
        </xpath>

        <!-- Remove decimal from Ordered qty (not-done state) -->
        <xpath expr="//span[@t-field='move.product_uom_qty']" position="replace">
            <span t-esc="int(move.product_uom_qty) if move.product_uom_qty == int(move.product_uom_qty) else move.product_uom_qty" class="text-nowrap"/>
        </xpath>
        <!-- Remove packaging brackets from Ordered column -->
        <xpath expr="//span[@t-if='move.product_packaging_id']" position="replace"/>

        <!-- Remove decimal from Delivered qty (not-done state) -->
        <xpath expr="//span[@t-field='move.quantity']" position="replace">
            <span t-esc="int(move.quantity) if move.quantity == int(move.quantity) else move.quantity" class="text-nowrap"/>
        </xpath>

        <!-- Remove decimal from backorder qty -->
        <xpath expr="//span[@t-field='bo_line.product_uom_qty']" position="replace">
            <span t-esc="int(bo_line.product_uom_qty) if bo_line.product_uom_qty == int(bo_line.product_uom_qty) else bo_line.product_uom_qty"/>
        </xpath>

        <!-- Fix Total row: integer totals, no item-code colspan -->
        <xpath expr="//table[@name='stock_move_table']/tbody" position="after">
            <tbody>
                <tr style="border-top: 2px solid black; font-weight: bold;">
                    <td colspan="2">Total</td>
                    <td class="text-end">
                        <t t-esc="int(sum(o.move_ids.mapped('product_uom_qty')))"/>
                    </td>
                    <td class="text-end">
                        <t t-esc="int(sum(o.move_ids.mapped('quantity')))"/>
                    </td>
                </tr>
            </tbody>
            <tbody t-if="o.note">
                <tr>
                    <td colspan="99" style="border: 0; padding-top: 10px; padding-bottom: 10px; font-size: 15pt;">
                        <strong>Remark / 備註：</strong>
                        <div style="white-space: pre-wrap; margin-top: 4px; font-size: 15pt;">
                            <span t-out="o.note"/>
                        </div>
                    </td>
                </tr>
            </tbody>
            <tbody style="page-break-before: always;">
                <tr style="page-break-before: always;">
                    <td colspan="99" style="border: 0; padding-top: 30px;">
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left;">
                            <div>I/We Received the above goods in good conditions<br/>&amp; agree the terms &amp; conditions stated above</div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"/>
                            <div style="margin-top: 5px;">Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left; margin-left: 5%;">
                            <div>For and on behalf of :<br/><strong><t t-esc="o.company_id.name"/></strong></div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"/>
                            <div style="margin-top: 5px;">Authorized Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                    </td>
                </tr>
            </tbody>
        </xpath>

        <!-- Fix Total row for done-state table: integer totals -->
        <xpath expr="//table[@name='stock_move_line_table']/tbody" position="after">
            <tbody>
                <t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')"/>
                <tr style="border-top: 2px solid black; font-weight: bold;">
                    <td t-att-colspan="has_serial_number and 2 or 1">Total</td>
                    <t t-if="not has_serial_number">
                        <td class="text-center">
                            <t t-esc="int(sum(o.move_line_ids.mapped('qty_done')))"/>
                        </td>
                    </t>
                    <td class="text-center">
                        <t t-esc="int(sum(o.move_line_ids.mapped('qty_done')))"/>
                    </td>
                </tr>
            </tbody>
            <tbody t-if="o.note">
                <tr>
                    <td colspan="99" style="border: 0; padding-top: 10px; padding-bottom: 10px; font-size: 15pt;">
                        <strong>Remark / 備註：</strong>
                        <div style="white-space: pre-wrap; margin-top: 4px; font-size: 15pt;">
                            <span t-out="o.note"/>
                        </div>
                    </td>
                </tr>
            </tbody>
            <tbody style="page-break-before: always;">
                <tr style="page-break-before: always;">
                    <td colspan="99" style="border: 0; padding-top: 30px;">
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left;">
                            <div>I/We Received the above goods in good conditions<br/>&amp; agree the terms &amp; conditions stated above</div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"/>
                            <div style="margin-top: 5px;">Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left; margin-left: 5%;">
                            <div>For and on behalf of :<br/><strong><t t-esc="o.company_id.name"/></strong></div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"/>
                            <div style="margin-top: 5px;">Authorized Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                    </td>
                </tr>
            </tbody>
        </xpath>

    </data>
</odoo>
