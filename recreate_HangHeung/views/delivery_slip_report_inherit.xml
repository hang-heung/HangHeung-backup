<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template id="delivery_slip_inherit" inherit_id="stock.report_delivery_document">

        <xpath expr="//div[@class='page']/h2" position="replace"></xpath>
        <xpath expr="//div[@class='page']/div[2]" position="replace"></xpath>
        <xpath expr="//div[@class='page']/div[3]" position="replace"></xpath>
        <xpath expr="//t[@t-set='address']" position="replace"></xpath>
        <xpath expr="//table[@name='stock_move_table']" position="before">
            <div style="margin-bottom: 6px;">
                <div style="display: inline-block; margin-right: 275px; width: 250px; vertical-align: top;">
                    <div class="col-7" name="div_incoming_address">
                        <t t-set="show_partner" t-value="False"/>
                        <div name="vendor_address" t-if="o.picking_type_id.code=='incoming' and partner">
                            <span>
                                <strong>Vendor Address:</strong>
                            </span>
                            <t t-set="show_partner" t-value="True"/>
                        </div>
                        <div name="customer_address"
                             t-if="o.picking_type_id.code=='outgoing' and partner and partner != partner.commercial_partner_id">
                            <span>
                                <strong>Customer Address:</strong>
                            </span>
                            <t t-set="show_partner" t-value="True"/>
                        </div>
                        <div t-if="show_partner" name="partner_header">
                            <div t-field="partner.commercial_partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True}'/>
                        </div>
                    </div>
                </div>

                <div style="display: inline-block; width: 300px; vertical-align: top;">
                    <div name="outgoing_delivery_address" t-if="o.should_print_delivery_address()">
                        <span>
                            <strong>Delivery Address:</strong>
                        </span>
                        <div t-out="o.move_ids[0].partner_id or o.partner_id"
                             t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </div>
                    <div name="outgoing_warehouse_address"
                         t-elif="o.picking_type_id.code != 'internal' and o.picking_type_id.warehouse_id.partner_id">
                        <span>
                            <strong>Warehouse Address:</strong>
                        </span>
                        <div t-field="o.picking_type_id.warehouse_id.partner_id"
                             t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </div>
                </div>
            </div>

            <!--<h2>
                <span t-field="o.name">WH/OUT/0001</span>
            </h2>-->
            <!-- Set current report name for external_layout_standard-->
            <t t-set="current_report_name" t-value="'stock.report_deliveryslip'"/>

            <div class="report-wrapping-flexbox clearfix row" style="margin-top: 4px; margin-bottom: 8px;">
                <div t-if="o.origin" style="display: inline-block; width: 30%; margin-right: 15px;" name="div_origin">
                    <strong style="color: #AF8489">Order:</strong>
                    <p t-field="o.origin" class="m-0">S0001</p>
                </div>
                <div t-if="o.state" style="display: inline-block; width: 30%;" name="div_sched_date">
                    <strong style="color: #AF8489">Shipping Date:</strong>
                    <p t-field="o.scheduled_date" class="m-0"/>
                </div>
                <div t-if="o.origin" style="display: inline-block; width: 30%;" name="div_sched_date">
                    <strong style="color: #AF8489">Customer Reference:</strong>
                    <!-- Determine last segment from full_origin_chain if available -->
		            <t t-set="source" t-value="o.full_origin_chain or o.origin or ''"/>
		            <t t-set="last_order_number" t-value="source.split('-')[-1].strip()"/>
                    <p t-esc="last_order_number" class="m-0"/>
                </div>
            </div>
            <!-- HH-CUSTOM: 嫁囍單 / B2B單 isolation flags carried from the
                 source SO through the intercompany chain. Shows on both
                 delivery slips and receipt slips. -->
            <div t-if="o.is_wedding_order or o.is_b2b_order"
                 style="margin: 4px 0 8px 0; padding: 4px 6px; border: 1px solid #AF8489; background: #FFF8F8; font-size: 12pt;">
                <strong style="color: #AF8489">訂單類型 / Order Type:</strong>
                <span t-if="o.is_wedding_order" style="margin-left: 8px; padding: 1px 6px; background: #C8102E; color: #fff; border-radius: 3px; font-weight: bold;">嫁囍單</span>
                <span t-if="o.is_b2b_order" style="margin-left: 8px; padding: 1px 6px; background: #1F4E79; color: #fff; border-radius: 3px; font-weight: bold;">B2B單</span>
            </div>
        </xpath>


        <!-- HH-CUSTOM: add an "Item Code" column (product.default_code) right
             after the Product column on the pending-moves table. -->
        <xpath expr="//table[@name='stock_move_table']//th[@name='th_sm_product']" position="after">
            <th name="th_sm_item_code"><strong>Item Code</strong></th>
        </xpath>
        <xpath expr="//table[@name='stock_move_table']//tr[@t-as='move']/td[1]" position="after">
            <td>
                <span t-esc="move.product_id.default_code or ''"/>
            </td>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody" position="after">
            <tbody>
                <tr style="border-top: 2px solid black; font-weight: bold;">
                    <td colspan="2">Total</td>
                    <td class="text-end">
                        <t t-esc="sum(o.move_ids.mapped('product_uom_qty'))"/>
                    </td>
                    <td class="text-end">
                        <t t-esc="sum(o.move_ids.mapped('quantity'))"/>
                    </td>
                </tr>
            </tbody>
            <tbody t-if="o.note">
                <tr>
                    <td colspan="99" style="border: 0; padding-top: 10px; padding-bottom: 10px; font-size: 15pt;">
                        <strong>Remark / 備註：</strong>
                        <div style="white-space: pre-wrap; margin-top: 4px; font-size: 15pt;">
                            <span t-out="o.note"/>
                        </div>
                    </td>
                </tr>
            </tbody>
            <tbody style="page-break-before: always;">
                <tr style="page-break-before: always;">
                    <td colspan="99" style="border: 0; padding-top: 30px;">
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left;">
                            <div>I/We Received the above goods in good conditions<br/>&amp; agree the terms &amp; conditions stated above</div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"></div>
                            <div style="margin-top: 5px;">Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left; margin-left: 5%;">
                            <div>For and on behalf of :<br/><strong><t t-esc="o.company_id.name"/></strong></div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"></div>
                            <div style="margin-top: 5px;">Authorized Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                    </td>
                </tr>
            </tbody>
        </xpath>

        <!-- HH-CUSTOM: add an "Item Code" column to the done-move-line table
             header. The td cells are injected by the helper-template inherits
             at the bottom of this file. -->
        <xpath expr="//table[@name='stock_move_line_table']//th[@name='th_sml_product']" position="after">
            <th name="th_sml_item_code"><strong>Item Code</strong></th>
        </xpath>

        <xpath expr="//table[@name='stock_move_line_table']/tbody" position="after">
            <tbody>
                <t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')"/>
                <tr style="border-top: 2px solid black; font-weight: bold;">
                    <td t-att-colspan="has_serial_number and 3 or 2">Total</td>
                    <t t-if="not has_serial_number">
                        <td class="text-center">
                            <t t-esc="sum(o.move_line_ids.mapped('qty_done'))"/>
                        </td>
                    </t>
                    <td class="text-center">
                        <t t-esc="sum(o.move_line_ids.mapped('qty_done'))"/>
                    </td>
                </tr>
            </tbody>
            <tbody t-if="o.note">
                <tr>
                    <td colspan="99" style="border: 0; padding-top: 10px; padding-bottom: 10px; font-size: 15pt;">
                        <strong>Remark / 備註：</strong>
                        <div style="white-space: pre-wrap; margin-top: 4px; font-size: 15pt;">
                            <span t-out="o.note"/>
                        </div>
                    </td>
                </tr>
            </tbody>
            <tbody style="page-break-before: always;">
                <tr style="page-break-before: always;">
                    <td colspan="99" style="border: 0; padding-top: 30px;">
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left;">
                            <div>I/We Received the above goods in good conditions<br/>&amp; agree the terms &amp; conditions stated above</div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"></div>
                            <div style="margin-top: 5px;">Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                        <div style="display: inline-block; width: 45%; vertical-align: top; text-align: left; margin-left: 5%;">
                            <div>For and on behalf of :<br/><strong><t t-esc="o.company_id.name"/></strong></div>
                            <div style="margin-top: 100px; border-top: 1px solid #000; width: 80%;"></div>
                            <div style="margin-top: 5px;">Authorized Signature &amp; Company Chop</div>
                            <div style="margin-top: 5px;">Date:</div>
                        </div>
                    </td>
                </tr>
            </tbody>
        </xpath>

        <!-- HH-CUSTOM: add Item Code column to the "Remaining quantities not
             yet delivered" backorder table that prints below the main table. -->
        <xpath expr="//table[@name='stock_backorder_table']//th[@name='th_sb_product']" position="after">
            <th name="th_sb_item_code"><strong>Item Code</strong></th>
        </xpath>
        <xpath expr="//table[@name='stock_backorder_table']//tr[@t-as='bo_line']/td[1]" position="after">
            <td>
                <span t-esc="bo_line.product_id.default_code or ''"/>
            </td>
        </xpath>

    </template>

    <!-- HH-CUSTOM: helper-template inherits to add the Item Code cell to the
         done-state delivery slip rows. These templates are called by
         stock.report_delivery_document for state='done' pickings. -->
    <template id="hh_stock_report_delivery_aggregated_move_lines"
              inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <xpath expr="//td[1]" position="after">
            <td>
                <span t-esc="aggregated_lines[line]['product'].default_code or ''"/>
            </td>
        </xpath>
    </template>

    <template id="hh_stock_report_delivery_has_serial_move_line"
              inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//td[1]" position="after">
            <td>
                <span t-esc="move_line.product_id.default_code or ''"/>
            </td>
        </xpath>
    </template>

</odoo>
