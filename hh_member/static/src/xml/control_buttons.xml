<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="hh_member.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='props.showRemainingButtons']/div/OrderlineNoteButton" position="after">
            <button class="control-button"
                    t-att-class="buttonClass"
                    t-attf-class="{{ hhGetFreeOffers().length ? 'highlight text-action' : 'disabled' }}"
                    t-on-click="() => this.hhClickFreeGift()">
                <i class="fa fa-gift me-1"/>會員免費贈品
            </button>
        </xpath>
    </t>
</templates>
