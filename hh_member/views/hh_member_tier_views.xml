<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hh_member_tier_list" model="ir.ui.view">
        <field name="name">hh.member.tier.list</field>
        <field name="model">hh.member.tier</field>
        <field name="arch" type="xml">
            <list string="會員等級" editable="bottom">
                <field name="name"/>
                <field name="min_spending"/>
                <field name="pricelist_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="earn_rate"/>
                <field name="redeem_value"/>
                <field name="tag_id" options="{'no_create_edit': True}"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="company_id" optional="hide"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_hh_member_tier_form" model="ir.ui.view">
        <field name="name">hh.member.tier.form</field>
        <field name="model">hh.member.tier</field>
        <field name="arch" type="xml">
            <form string="會員等級">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Tier 1"/></h1>
                    </div>
                    <group>
                        <group string="資格 / Eligibility">
                            <field name="min_spending"/>
                            <field name="pricelist_id" options="{'no_create': True}"/>
                            <field name="tag_id" options="{'no_create_edit': True}"/>
                        </group>
                        <group string="積分 / Loyalty Points">
                            <field name="earn_rate"/>
                            <field name="redeem_value"/>
                        </group>
                    </group>
                    <group>
                        <group string="其他 / Misc">
                            <field name="active"/>
                            <field name="company_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hh_member_tier" model="ir.actions.act_window">
        <field name="name">會員等級配置</field>
        <field name="res_model">hh.member.tier</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">建立會員等級</p>
            <p>每一級需要設定最低消費門檻、適用價格表、賺取比率、兌換價值，以及對應的會員標籤。</p>
        </field>
    </record>

    <menuitem
        id="menu_hh_member_tier_config"
        name="會員等級"
        parent="point_of_sale.menu_point_root"
        action="action_hh_member_tier"
        sequence="95"/>

</odoo>
