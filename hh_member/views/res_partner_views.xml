<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_hh_member" model="ir.ui.view">
        <field name="name">res.partner.form.hh.member</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="before">
                <page string="會員計劃" name="hh_member_plan">
                    <group string="會員等級">
                        <group>
                            <field name="member_tier_id" readonly="1"
                                   string="會員等級"
                                   options="{'no_open': True}"/>
                            <field name="subscription_date" readonly="1"
                                   string="成為會員日期"
                                   invisible="not subscription_date"/>
                        </group>
                    </group>
                    <separator string="買X送一進度"/>
                    <field name="hh_free_progress_ids" nolabel="1" readonly="1">
                        <list string="買X送一進度" create="false" delete="false" edit="false">
                            <field name="rule_id"/>
                            <field name="accumulated_qty"/>
                            <field name="threshold_qty"/>
                            <field name="grant_count"/>
                            <field name="last_grant_date"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
