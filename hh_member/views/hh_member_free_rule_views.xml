<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hh_member_free_rule_list" model="ir.ui.view">
        <field name="name">hh.member.free.rule.list</field>
        <field name="model">hh.member.free.rule</field>
        <field name="arch" type="xml">
            <list string="會員優惠">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="threshold_qty"/>
                <field name="once_per_member" widget="boolean_toggle"/>
                <field name="free_product_ids" widget="many2many_tags" optional="show"/>
                <field name="free_category_ids" widget="many2many_tags" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_hh_member_free_rule_form" model="ir.ui.view">
        <field name="name">hh.member.free.rule.form</field>
        <field name="model">hh.member.free.rule</field>
        <field name="arch" type="xml">
            <form string="會員優惠">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="買10送1 蛋糕"/></h1>
                    </div>
                    <group>
                        <group string="條件 / Condition">
                            <field name="threshold_qty"/>
                            <field name="once_per_member"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="合資格產品" name="qualifying_products">
                            <field name="qualifying_product_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </page>
                        <page string="合資格產品類別" name="qualifying_categories">
                            <field name="qualifying_category_ids"
                                   widget="many2many_tags"/>
                        </page>
                        <page string="免費贈品 (產品)" name="free_products">
                            <field name="free_product_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </page>
                        <page string="免費贈品 (類別)" name="free_categories">
                            <field name="free_category_ids"
                                   widget="many2many_tags"/>
                        </page>
                    </notebook>
                    <p class="text-muted">
                        產品只要符合「合資格產品」名單，或其產品類別（或子類別）
                        在「合資格產品類別」中，即計入累積數量。會員於好妙 POS
                        累積購買（跨交易及同一購物車）達所需數量 (X) 後，收銀
                        可於 POS 加入免費贈品，系統自動以 100% 折扣使其免費，
                        並扣減累積數量。
                    </p>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hh_member_free_rule" model="ir.actions.act_window">
        <field name="name">會員優惠</field>
        <field name="res_model">hh.member.free.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">建立買X送一規則</p>
            <p>設定合資格產品（或類別）、所需累積數量，以及免費贈品。</p>
        </field>
    </record>

    <menuitem
        id="menu_hh_member_free_rule"
        name="會員優惠"
        parent="hh_member.menu_hh_member_config_root"
        action="action_hh_member_free_rule"
        sequence="20"/>

</odoo>
