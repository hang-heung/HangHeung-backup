<odoo>
    <record id="purchase_order_report_wizard" model="ir.ui.view">
        <field name="name">purchase.order.report.wizard.form</field>
        <field name="model">purchase.order.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Retail DN/PO Report">
                <group>
                    <field name="date_from"/>
		    <field name="date_to"/>
		    <field name="company_id"/>
                </group>
                <footer>
                    <button name="action_export_xlsx" type="object" string="Export XLSX" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_purchase_order_report_wizard" model="ir.actions.act_window">
        <field name="name">Retail DN/PO Report</field>
        <field name="res_model">purchase.order.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_purchase_order_report"
              name="Retail DN/PO Report"
              parent="stock.menu_warehouse_report"
              sequence="97" action="pos_shop_report.action_purchase_order_report_wizard"/>
</odoo>
