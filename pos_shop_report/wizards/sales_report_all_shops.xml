<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_sales_report_all_shops_wizard" model="ir.ui.view">
        <field name="name">sales.report.all.shops.wizard.form</field>
        <field name="model">sales.report.all.shops.wizard</field>
        <field name="arch" type="xml">
            <form string="Sales Report All Shops">
                <group>
                    <group>
                        <field name="start_date"/>
                    </group>
                    <group>
                        <field name="end_date"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_excel" string="Generate Excel" type="object" class="btn-primary"/>
                    <button name="action_generate_pdf" string="Generate PDF" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sales_report_all_shops_wizard" model="ir.actions.act_window">
        <field name="name">日結報表(全線)</field>
        <field name="res_model">sales.report.all.shops.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sales_report_all_shops_wizard"/>
        <field name="target">new</field>
    </record>

</odoo>
