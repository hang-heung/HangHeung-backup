<odoo>
    <record id="view_product_sales_detail_report_wizard_form" model="ir.ui.view">
        <field name="name">product.sales.detail.report.wizard.form</field>
        <field name="model">product.sales.detail.report.wizard</field>
        <field name="arch" type="xml">
            <form string="產品銷售明細報告 (分店)">
                <group>
                    <field name="store_id"/>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>
                <footer>
                    <button string="Generate Report" type="object" name="action_generate_excel" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_product_sales_detail_report_wizard" model="ir.actions.act_window">
        <field name="name">產品銷售明細報告 (分店)</field>
        <field name="res_model">product.sales.detail.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_product_sales_detail_report_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
