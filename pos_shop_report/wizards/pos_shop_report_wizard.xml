<odoo>
    <record id="view_pos_shop_report_wizard" model="ir.ui.view">
        <field name="name">pos.shop.report.wizard.form</field>
        <field name="model">pos.shop.report.wizard</field>
        <field name="arch" type="xml">
            <form string="POS Shop Report">
                <group>
                    <field name="shop_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                </group>
                <footer>
                    <button name="generate_report" type="object" string="Generate Report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_shop_report_wizard" model="ir.actions.act_window">
        <field name="name">分店庫存及銷售報告</field>
        <field name="res_model">pos.shop.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pos_shop_report_wizard"/>
        <field name="target">new</field>
    </record>
</odoo>
