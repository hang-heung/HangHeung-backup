<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_daily_product_sales_inventory_report_wizard" model="ir.ui.view">
        <field name="name">daily.product.sales.inventory.report.form</field>
        <field name="model">daily.product.sales.inventory.report</field>
        <field name="arch" type="xml">
            <form string="POS Shop Report">
                <group>
                    <field name="shop_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                </group>
                <footer>
                    <button name="generate_xls_report" type="object" string="Excel" class="btn-success"/>
                    <button name="generate_pdf_report" type="object" string="PDF" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_daily_product_sales_inventory_report" model="ir.actions.act_window">
        <field name="name">貨品銷售及庫存報表</field>
        <field name="res_model">daily.product.sales.inventory.report</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_daily_product_sales_inventory_report_wizard"/>
        <field name="target">new</field>
    </record>
</odoo>
