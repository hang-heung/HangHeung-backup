<odoo>
    <record id="view_time_period_sales_report_individual_form" model="ir.ui.view">
        <field name="name">time.period.sales.report.individual.form</field>
        <field name="model">time.period.sales.report.individual</field>
        <field name="arch" type="xml">
            <form string="時段銷售報告 (分店)">
                <group>
                    <field name="shop_id"/>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>
                <footer>
                    <button string="Generate Report" type="object" name="action_generate_excel" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_time_period_sales_report_individual" model="ir.actions.act_window">
        <field name="name">時段銷售報告 (分店)</field>
        <field name="res_model">time.period.sales.report.individual</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_time_period_sales_report_individual_form"/>
        <field name="target">new</field>
    </record>

</odoo>
