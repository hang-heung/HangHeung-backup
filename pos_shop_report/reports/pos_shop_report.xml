<odoo>
  <template id="report_pos_shop_template">
    <t t-call="web.basic_layout">
      <main class="page">
        <div style="text-align: right; font-size: 9pt; font-weight: bold; margin-bottom: 4px;">
          <t t-esc="docs.company_name or ''"/>
        </div>
        <h2 style="text-align: center;"><t t-esc="docs.company_name"/></h2>
        <div style="text-align: center;margin-top: 20px;">
          <h3>Shop Name: <t t-esc="docs.shop_id.name"/></h3>
          <p><t t-esc="docs.shop_address"/></p>
          <p>Tel: <t t-esc="docs.shop_phone"/></p>
        </div>

        <div style="margin-bottom: 10px;">
          <h3 style="text-align: left; margin: 0 0 5px 0;">
            Report - Shop Sales Report and Inventory Report
          </h3>
          <h5 style="text-align: left; margin: 0;">
            <strong>Date From:</strong> <t t-esc="docs.date_start"/>
            <strong>Date To:</strong> <t t-esc="docs.date_end"/>
          </h5>
          <h5 style="text-align: left; margin: 0;">
            <strong>Printed On:</strong>
            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/>
          </h5>
        </div>

        <table class="table table-sm table-bordered" style="margin-top: 20px; table-layout: fixed; width: 100%; font-size: 9pt; word-wrap: break-word;">
          <colgroup>
            <col style="width: 9%;"/>
            <col style="width: 22%;"/>
            <col style="width: 7%;"/>
            <col style="width: 7%;"/>
            <col style="width: 7%;"/>
            <col style="width: 6%;"/>
            <col style="width: 7%;"/>
            <col style="width: 7%;"/>
            <col style="width: 9%;"/>
            <col style="width: 9%;"/>
            <col style="width: 10%;"/>
          </colgroup>
          <thead style="background-color: #f0f0f0;">
            <tr>
              <th>貨品</th>
              <th>貨品說明</th>
              <th>前一天上傳數</th>
              <th>時段進貨數總和</th>
              <th>當天棄貨數</th>
              <th>銷售數</th>
              <th>銷售退貨數</th>
              <th>總結數</th>
              <th>總銷售 標準金額</th>
              <th>折扣金額</th>
              <th>總銷售 最終金額</th>
            </tr>
          </thead>
          <tbody>
            <t t-if="docs.report_lines">
              <t t-set="total_previous_stock" t-value="sum([line['previous_stock'] for line in docs.report_lines])"/>
              <t t-set="total_stock_in" t-value="sum([line['stock_in'] for line in docs.report_lines])"/>
              <t t-set="total_scrap_qty" t-value="sum([line['scrap_qty'] for line in docs.report_lines])"/>
              <t t-set="total_sales_qty" t-value="sum([line['sales_qty'] for line in docs.report_lines])"/>
              <t t-set="total_sales_refund_qty" t-value="sum([line['sales_refund_qty'] for line in docs.report_lines])"/>
              <t t-set="total_qty_today" t-value="sum([line['total_qty_today'] for line in docs.report_lines])"/>
              <t t-set="total_sales_amount" t-value="sum([line['sales_amount'] for line in docs.report_lines])"/>
              <t t-set="total_discount_amount" t-value="sum([line['discount_amount'] for line in docs.report_lines])"/>
              <t t-set="total_final_amount" t-value="sum([line['final_amount'] for line in docs.report_lines])"/>
              <t t-foreach="docs.report_lines" t-as="line">
                <tr>
                  <td><t t-esc="line['sku']"/></td>
                  <td><t t-esc="line['name']"/></td>
                  <td><t t-esc="line['previous_stock']"/></td>
                  <td><t t-esc="line['stock_in']"/></td>
                  <td><t t-esc="-line['scrap_qty']"/></td>
                  <td><t t-esc="line['sales_qty']"/></td>
                  <td><t t-esc="line['sales_refund_qty']"/></td>
                  <td><t t-esc="line['total_qty_today']"/></td>
                  <td><t t-esc="'%.2f' % line['sales_amount']"/></td>
                  <td><t t-esc="'%.2f' % line['discount_amount']"/></td>
                  <td><t t-esc="'%.2f' % line['final_amount']"/></td>
                </tr>
              </t>

              <tr style="font-weight: bold; background-color: #f9f9f9; font-size: 7pt;">
                <td colspan="2" style="text-align: right;">Subtotal:</td>
                <td><t t-esc="total_previous_stock"/></td>
                <td><t t-esc="total_stock_in"/></td>
                <td><t t-esc="-total_scrap_qty"/></td>
                <td><t t-esc="total_sales_qty"/></td>
                <td><t t-esc="total_sales_refund_qty"/></td>
                <td><t t-esc="total_qty_today"/></td>
                <td><t t-esc="'%.2f' % total_sales_amount"/></td>
                <td><t t-esc="'%.2f' % total_discount_amount"/></td>
                <td><t t-esc="'%.2f' % total_final_amount"/></td>
              </tr>
              <tr>
                <td colspan="10" style="text-align: right; font-weight: bold;">Final Total:</td>
                <td><t t-esc="'%.2f' % total_final_amount"/></td>
              </tr>
             <tr>
                <td colspan="10" style="text-align: right; font-weight: bold;">Deducted Coupons:</td>
                <td><t t-esc="'%.2f' % (docs.coupon_discount_total or 0.0)"/></td>
              </tr>
              <tr>
                <td colspan="10" style="text-align: right; font-weight: bold;">Grand Total:</td>
                <td><t t-esc="'%.2f' % (total_final_amount - (docs.coupon_discount_total or 0.0))"/></td>
              </tr>
              <tr>

              <td colspan="5" style="font-weight: bold; padding-top: 20px;">List of Payment Methods</td>
            </tr>
            <t t-if="docs.payment_breakdown">
              <t t-foreach="docs.payment_breakdown.items()" t-as="pay">
                <tr>
                  <td colspan="4" style="text-align: left;"><t t-esc="pay[0]"/>:</td>
                  <td><t t-esc="'%.2f' % pay[1]"/></td>
                </tr>
              </t>
            </t>

            </t>
          </tbody>
        </table>

        <t t-if="docs.coupon_lines">
          <h4 style="text-align: left; margin: 20px 0 5px 0;">Coupon Allocation Summary</h4>
          <table class="table table-sm table-bordered" style="table-layout: fixed; width: 100%; font-size: 9pt; word-wrap: break-word;">
            <colgroup>
              <col style="width: 22%;"/>
              <col style="width: 11%;"/>
              <col style="width: 25%;"/>
              <col style="width: 9%;"/>
              <col style="width: 11%;"/>
              <col style="width: 11%;"/>
              <col style="width: 11%;"/>
            </colgroup>
            <thead style="background-color: #f0f0f0;">
              <tr>
                <th>程式 / Program</th>
                <th>SKU</th>
                <th>名稱 / Name</th>
                <th>面值 / Face</th>
                <th>已分配未啟用</th>
                <th>期內已贖回</th>
                <th>期內銷售贖回額</th>
              </tr>
            </thead>
            <tbody>
              <t t-set="t_face" t-value="sum([c['face_value'] for c in docs.coupon_lines])"/>
              <t t-set="t_alloc" t-value="sum([c['allocated_not_activated'] for c in docs.coupon_lines])"/>
              <t t-set="t_redeem" t-value="sum([c['redeemed_in_period'] for c in docs.coupon_lines])"/>
              <t t-set="t_sales" t-value="sum([c['redemption_sales'] for c in docs.coupon_lines])"/>
              <t t-foreach="docs.coupon_lines" t-as="cline">
                <tr>
                  <td><t t-esc="cline['program_name']"/></td>
                  <td><t t-esc="cline['sku']"/></td>
                  <td><t t-esc="cline['name']"/></td>
                  <td><t t-esc="'%.2f' % cline['face_value']"/></td>
                  <td><t t-esc="cline['allocated_not_activated']"/></td>
                  <td><t t-esc="cline['redeemed_in_period']"/></td>
                  <td><t t-esc="'%.2f' % cline['redemption_sales']"/></td>
                </tr>
              </t>
              <tr style="font-weight: bold; background-color: #f9f9f9; font-size: 8pt;">
                <td colspan="3" style="text-align: right;">Subtotal:</td>
                <td><t t-esc="'%.2f' % t_face"/></td>
                <td><t t-esc="t_alloc"/></td>
                <td><t t-esc="t_redeem"/></td>
                <td><t t-esc="'%.2f' % t_sales"/></td>
              </tr>
            </tbody>
          </table>
        </t>
      </main>
    </t>
  </template>
</odoo>
