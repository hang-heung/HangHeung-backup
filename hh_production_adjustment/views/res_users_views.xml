<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_production_order" model="ir.ui.view">
        <field name="name">res.users.form.production.order</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Add after partner_access_role in the same top group, same pattern -->
            <xpath expr="//page[@name='access_rights']/group[1]" position="inside">
                <field name="production_order_user"
                       widget="boolean_toggle"
                       string="Production Order User"/>
                <field name="production_adj_user"
                       widget="boolean_toggle"
                       string="Production Adjustment User"/>
            </xpath>
        </field>
    </record>
</odoo>
