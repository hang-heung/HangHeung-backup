<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_production_order" model="ir.actions.report">
        <field name="name">Production Order</field>
        <field name="model">hh.production.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hh_production_adjustment.report_production_order_document</field>
        <field name="report_file">hh_production_adjustment.report_production_order_document</field>
        <field name="binding_model_id" ref="model_hh_production_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_production_order_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2>Production Order</h2>
                                <h3 class="text-muted"><t t-esc="o.name"/></h3>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Date:</strong>
                                <span><t t-esc="o.date" t-options='{"widget": "datetime"}'/></span><br/>
                                <strong>Status:</strong>
                                <span><t t-esc="o.state.capitalize()"/></span><br/>
                                <t t-if="o.note">
                                    <strong>Notes:</strong>
                                    <span><t t-esc="o.note"/></span>
                                </t>
                            </div>
                        </div>

                        <!-- Warehouse info -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Consume From:</strong>
                                <span> <t t-esc="o.consume_warehouse_id.name"/></span>
                                <span class="text-muted"> (<t t-esc="o.consume_warehouse_id.lot_stock_id.complete_name"/>)</span>
                            </div>
                            <div class="col-6">
                                <strong>Produce To:</strong>
                                <span> <t t-esc="o.produce_warehouse_id.name"/></span>
                                <span class="text-muted"> (<t t-esc="o.produce_warehouse_id.lot_stock_id.complete_name"/>)</span>
                            </div>
                        </div>

                        <!-- Raw Materials -->
                        <t t-if="o.consume_line_ids">
                            <h4 class="mt-3">Raw Materials (Consume)</h4>
                            <table class="table table-sm table-bordered">
                                <thead class="table-secondary">
                                    <tr>
                                        <th>#</th>
                                        <th>Product</th>
                                        <th class="text-end">Qty to Deduct</th>
                                        <th>Unit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.consume_line_ids" t-as="line">
                                        <tr>
                                            <td><t t-esc="line_index + 1"/></td>
                                            <td><t t-esc="line.product_id.display_name"/></td>
                                            <td class="text-end"><t t-esc="line.qty" t-options='{"widget": "float", "precision": 2}'/></td>
                                            <td><t t-esc="line.product_uom_id.name"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Produced Goods -->
                        <t t-if="o.produce_line_ids">
                            <h4 class="mt-3">Produced Goods</h4>
                            <table class="table table-sm table-bordered">
                                <thead class="table-secondary">
                                    <tr>
                                        <th>#</th>
                                        <th>Product</th>
                                        <th class="text-end">Qty to Add</th>
                                        <th>Unit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.produce_line_ids" t-as="line">
                                        <tr>
                                            <td><t t-esc="line_index + 1"/></td>
                                            <td><t t-esc="line.product_id.display_name"/></td>
                                            <td class="text-end"><t t-esc="line.qty" t-options='{"widget": "float", "precision": 2}'/></td>
                                            <td><t t-esc="line.product_uom_id.name"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Transfer references (if validated) -->
                        <t t-if="o.state == 'done'">
                            <div class="row mt-4">
                                <div class="col-12">
                                    <strong>Generated Transfers:</strong>
                                    <t t-if="o.consumption_picking_id">
                                        &amp;nbsp; Consumption: <t t-esc="o.consumption_picking_id.name"/>
                                    </t>
                                    <t t-if="o.output_picking_id">
                                        &amp;nbsp;&amp;nbsp; Output: <t t-esc="o.output_picking_id.name"/>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <!-- Signature row -->
                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">Prepared by</div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">Checked by</div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">Approved by</div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
