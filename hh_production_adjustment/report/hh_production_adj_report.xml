<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_production_adj" model="ir.actions.report">
        <field name="name">Production Adjustment</field>
        <field name="model">hh.production.adj</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hh_production_adjustment.report_production_adj_document</field>
        <field name="report_file">hh_production_adjustment.report_production_adj_document</field>
        <field name="binding_model_id" ref="model_hh_production_adj"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_production_adj_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2>Production Adjustment</h2>
                                <h3 class="text-muted"><t t-esc="o.name"/></h3>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Date: </strong><span><t t-esc="o.date" t-options='{"widget": "datetime"}'/></span><br/>
                                <strong>Warehouse: </strong><span><t t-esc="o.warehouse_id.name"/></span><br/>
                                <strong>Status: </strong><span><t t-esc="o.state.capitalize()"/></span><br/>
                                <t t-if="o.note">
                                    <strong>Notes: </strong><span><t t-esc="o.note"/></span>
                                </t>
                            </div>
                        </div>

                        <table class="table table-sm table-bordered mt-3">
                            <thead class="table-secondary">
                                <tr>
                                    <th>#</th>
                                    <th>Product</th>
                                    <th class="text-end">Quantity (+/-)</th>
                                    <th>Unit</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line_index + 1"/></td>
                                        <td><t t-esc="line.product_id.display_name"/></td>
                                        <td class="text-end"
                                            t-attf-style="color: {{ 'green' if line.qty > 0 else 'red' }};">
                                            <t t-esc="line.qty" t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                        <td><t t-esc="line.product_uom_id.name"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">Prepared by</div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">Checked by</div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid #000; margin-top: 40px; padding-top: 4px;">Approved by</div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
