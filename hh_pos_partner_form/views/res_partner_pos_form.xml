<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hide a set of non-essential fields when the partner form is opened
         from POS (context.from_pos = True). Backend form is unaffected. -->
    <record id="view_partner_form_hh_pos_hide" model="ir.ui.view">
        <field name="name">res.partner.form.hh.pos.hide</field>
        <field name="model">res.partner</field>
        <!-- Inherit recreate_HangHeung's partner view so all custom fields it
             adds are already present in the assembled tree we target. -->
        <field name="inherit_id" ref="recreate_HangHeung.view_contact_form_inherit"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='contact_number']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='alternative_contact_name']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='customer_credit_limit']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='credit_limit']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='crdr_due_days']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='customer_category_id']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='purchase_auto_confirm']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <!-- Hide title only when the field is actually in the form. The
                 `occupation` field requested by the user does not exist on
                 res.partner in this database; skipped to avoid view-build
                 errors. -->
            <xpath expr="//field[@name='title']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='terms']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='vendor']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='customer']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='is_internal_contact']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <!-- Additional fields requested (round 2) -->
            <xpath expr="//field[@name='company_name']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='function']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='mobile']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='fax_number']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='lang']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <!-- Studio-created B2B customer flag -->
            <xpath expr="//field[@name='x_studio_b2b_customer']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <!-- Hide tabs -->
            <xpath expr="//page[@name='contact_addresses']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//page[@name='accounting']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

            <xpath expr="//page[@name='membership']" position="attributes">
                <attribute name="invisible">context.get('from_pos')</attribute>
            </xpath>

        </field>
    </record>
</odoo>
