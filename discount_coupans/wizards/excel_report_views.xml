<odoo>

    <record id="view_coupon_activated_excel_wizard" model="ir.ui.view">
        <field name="name">coupon.activated.excel.wizard.form</field>
        <field name="model">coupon.activated.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="已生效禮券">
                <group>
                    <div>Download Activated Coupons report</div>
                    <field name="from_date"
                           widget="date"
                           string="From Date"/>
                    <field name="to_date"
                           widget="date"
                           string="To Date"/>
                </group>
                <footer>
                    <button name="action_generate_excel"
                            string="Generate Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_coupon_inactivated_excel_wizard" model="ir.ui.view">
        <field name="name">coupon.inactivated.excel.wizard.form</field>
        <field name="model">coupon.inactivated.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="已失效禮券">
                <group>
                    <div>Download Inactivated Coupons report</div>
                    <field name="from_date"
                           widget="date"
                           string="From Date"/>
                    <field name="to_date"
                           widget="date"
                           string="To Date"/>
                </group>
                <footer>
                    <button name="action_generate_excel"
                            string="Generate Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_coupon_used_excel_wizard" model="ir.ui.view">
        <field name="name">coupon.used.excel.wizard.form</field>
        <field name="model">coupon.used.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="禮券兌換報告 (按舖)">
                <group>
                    <div>Download Used Coupons report</div>
                    <field name="from_date"
                           widget="date"
                           string="From Date"/>
                    <field name="to_date"
                           widget="date"
                           string="To Date"/>
                </group>
                <footer>
                    <button name="action_generate_excel"
                            string="Generate Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_coupon_transfer_excel_wizard" model="ir.ui.view">
        <field name="name">coupon.transfer.excel.wizard.form</field>
        <field name="model">coupon.transfer.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="禮券到舖表">
                <group>
                    <div>Download Transfer Coupons report</div>
                    <field name="shop_ids" widget="many2many_tags"/>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>
                <footer>
                    <button name="action_generate_transfer_excel"
                            string="Generate Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="view_coupon_summary_excel_wizard" model="ir.ui.view">
        <field name="name">coupon.summary.excel.wizard.form</field>
        <field name="model">coupon.summary.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="禮券生效及兌換報表">
                <group>
                    <field name="from_date"/>
                    <field name="to_date"/>
                    <field name="program_ids" widget="many2many_tags"/>
                    <field name="activated_shop_ids" widget="many2many_tags"/>
                    <field name="sold_shop_ids" widget="many2many_tags" string="Redeemed Shops"/>
                </group>

                <footer>
                    <button name="action_generate_report_excel"
                            type="object"
                            string="Generate Excel"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_coupon_excel" model="ir.actions.act_window">
        <field name="name">已生效禮券</field>
        <field name="res_model">coupon.activated.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_coupon_activated_excel_wizard"/>
        <field name="target">new</field>
    </record>

    <record id="action_coupon_inactivated_excel" model="ir.actions.act_window">
        <field name="name">已失效禮券</field>
        <field name="res_model">coupon.inactivated.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_coupon_inactivated_excel_wizard"/>
        <field name="target">new</field>
    </record>

    <record id="action_coupon_used_excel" model="ir.actions.act_window">
        <field name="name">禮券兌換報告 (按舖)</field>
        <field name="res_model">coupon.used.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_coupon_used_excel_wizard"/>
        <field name="target">new</field>
    </record>

     <record id="action_coupon_transfer_excel" model="ir.actions.act_window">
        <field name="name">禮券到舖表</field>
        <field name="res_model">coupon.transfer.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_coupon_transfer_excel_wizard"/>
        <field name="target">new</field>
    </record>

    <record id="action_coupon_summary_excel_wizard" model="ir.actions.act_window">
        <field name="name">禮券生效及兌換報表</field>
        <field name="res_model">coupon.summary.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_coupon_excel_report"
              name="Coupon Report"
              parent="point_of_sale.menu_point_rep"
              sequence="4"/>

    <menuitem id="menu_coupon_activated"
              name="Coupon Made (Activated)"
              parent="menu_coupon_excel_report"
              action="action_coupon_excel"
              sequence="2"/>

    <menuitem id="menu_coupon_inactivated"
              name="Coupon Made (Inactivated)"
              parent="menu_coupon_excel_report"
              action="action_coupon_inactivated_excel"
              sequence="3"/>

    <menuitem id="menu_coupon_used"
              name="Coupon Used (Along with which POS)"
              parent="menu_coupon_excel_report"
              action="action_coupon_used_excel"
              sequence="4"/>

    <menuitem id="menu_coupon_transfer"
              name="Coupon Transfer Summary"
              parent="menu_coupon_excel_report"
              action="action_coupon_transfer_excel"
              sequence="4"/>

    <menuitem id="menu_coupon_summary_report"
              name="Coupon Summary Report"
              parent="menu_coupon_excel_report"
              action="action_coupon_summary_excel_wizard"
              sequence="5"/>
</odoo>
