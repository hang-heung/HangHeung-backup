                            <strong><t t-esc="po.date_planned.strftime('%Y-%m-%d')"/></strong>
                        </div>
                    </t>
                </div>

                <div class="card mx-auto" style="max-width:620px">
                    <div class="card-header small fw-semibold text-muted">
                        訂單明細 Order Summary
                        <span class="float-end"><t t-esc="len(po.order_line)"/> 款產品</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 hh-summary-table">
                            <thead>
                                <tr>
                                    <th>產品代碼</th>
                                    <th>產品名稱</th>
                                    <th class="text-end">數量</th>
                                    <th>單位</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="po.order_line" t-as="line">
                                    <tr>
                                        <td class="small text-monospace">
                                            <t t-esc="line.product_id.default_code or ''"/>
                                        </td>
                                        <td><t t-esc="line.product_id.name"/></td>
                                        <td class="text-end fw-semibold">
                                            <t t-esc="'%g' % line.product_qty"/>
                                        </td>
                                        <td class="text-muted small">
                                            <t t-esc="line.product_uom.name"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
