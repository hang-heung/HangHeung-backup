            <t t-if="hh_portal_control">
                <style>
                    .o_portal_index_card:has(> a[href*="filterby=invoices"]) { display: none !important; }
                </style>
                <div class="row mb-4">
                    <t t-if="not hh_portal_is_hangheung">
                        <div class="col-md-6 mb-3">
                            <a href="/my/upload-sales" class="d-block text-decoration-none">
                                <div class="card hh-action-tile h-100">
                                    <div class="card-body py-3 px-4 d-flex align-items-center gap-3">
                                        <span class="tile-icon"><i class="fa fa-upload"/></span>
                                        <div>
                                            <div class="fw-bold">上載購物紀錄</div>
                                            <div class="text-muted small">Upload Purchase Records</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <a href="/my/place-order" class="d-block text-decoration-none">
                                <div class="card hh-action-tile h-100">
                                    <div class="card-body py-3 px-4 d-flex align-items-center gap-3">
                                        <span class="tile-icon"><i class="fa fa-shopping-basket"/></span>
                                        <div>
                                            <div class="fw-bold">訂貨單</div>
                                            <div class="text-muted small">Place Order</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-md-5 mb-3">
                            <a href="/my/place-order" class="d-block text-decoration-none">
                                <div class="card hh-action-tile h-100">
                                    <div class="card-body py-3 px-4 d-flex align-items-center gap-3">
                                        <span class="tile-icon"><i class="fa fa-shopping-basket"/></span>
                                        <div>
                                            <div class="fw-bold">客戶訂貨單</div>
                                            <div class="text-muted small">Place Order</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>


    <!--
    ================================================================
    Rename portal home tile titles + hide Connection/Security tile.
    ================================================================
    -->
    <template id="portal_my_home_rename_titles"
              inherit_id="portal.portal_my_home"
              name="HH Rename Portal Home Tile Titles"
              priority="35">
        <xpath expr="//div[@id='portal_client_category']//t[@t-set='url' and contains(@t-value, '/my/orders')]/preceding-sibling::t[@t-set='title']" position="replace">
            <t t-set="title">銷售紀錄</t>
        </xpath>
        <xpath expr="//div[@id='portal_vendor_category']//t[@t-set='url' and contains(@t-value, '/my/purchase')]/preceding-sibling::t[@t-set='title']" position="replace">
            <t t-set="title">補貨紀錄</t>
        </xpath>
        <xpath expr="//div[@id='portal_common_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>


    <!--
    ================================================================
    Shared product table body — called by both order forms.
    Renders the grouped product table + floating bar + JS.
    ================================================================
    -->
    <template id="hh_portal_order_form_body" name="HH Order Form Body (shared)">
        <t t-call="hh_portal_orders.hh_portal_order_table_style"/>

        <div class="table-responsive">
            <table class="table table-bordered table-sm align-middle hh-order-table mb-0">
                <thead>
                    <tr>
                        <th style="min-width:108px">產品代碼</th>
                        <th style="min-width:88px">舊貨號</th>
                        <th style="min-width:160px">產品名稱</th>
                        <th style="min-width:88px">包裝規格</th>
                        <th style="width:110px" class="text-end">數量</th>
                        <th style="width:130px">單位</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="grouped_products" t-as="group">
                        <tr class="hh-cat-row">
                            <td colspan="6">
                                <t t-if="group['code']">
                                    <span class="badge me-2"><t t-esc="group['code']"/></span>
                                </t>
                                <t t-esc="group['name']"/>
                            </td>
                        </tr>
                        <t t-foreach="group['products']" t-as="p">
                            <tr>
                                <td data-label="產品代碼">
                                    <span class="text-monospace small"><t t-esc="p.default_code or ''"/></span>
                                </td>
                                <td data-label="舊貨號">
                                    <span class="text-muted small"><t t-esc="p.old_item_number or ''"/></span>
                                </td>
                                <td data-label="產品名稱"><t t-esc="p.name"/></td>
                                <td data-label="包裝規格">
                                    <span class="text-muted small"><t t-esc="p.product_tmpl_id.packing_spec or ''"/></span>
                                </td>
                                <td data-label="數量">
                                    <input type="number" min="0" step="any"
                                           t-attf-name="qty_{{p.id}}"
                                           class="form-control form-control-sm text-end"
                                           placeholder="0"/>
                                </td>
                                <td data-label="單位">
                                    <select t-attf-name="uom_{{p.id}}" class="form-select form-select-sm">
                                        <option value="base"><t t-esc="p.uom_id.name"/></option>
                                        <t t-if="p.product_tmpl_id.alternate_unit_of_measure and p.product_tmpl_id.conversion_rate">
                                            <option value="alt">
                                                <t t-esc="p.product_tmpl_id.alternate_unit_of_measure.name"/>
                                                (×<t t-esc="p.product_tmpl_id.conversion_rate"/>)
                                            </option>
                                        </t>
                                    </select>
                                </td>
                            </tr>
                        </t>
                    </t>
                    <t t-if="not grouped_products">
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fa fa-inbox fa-2x d-block mb-2"/>
                                產品列表為空 — 請聯絡管理員設定您的帳戶。
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>

        <!-- Floating bar: shown by JS when any qty > 0 -->
        <div id="hh-sticky-bar" class="hh-sticky-bar d-none">
            <div class="container d-flex justify-content-between align-items-center">
                <span id="hh-bar-summary" class="small fw-semibold"></span>
                <button type="submit" class="btn-submit-bar">提交 Submit</button>
            </div>
        </div>

        <script type="text/javascript">
        (function () {
            var form    = document.getElementById('hh-order-form');
            var inputs  = form ? form.querySelectorAll('input[name^="qty_"]') : [];
            var bar     = document.getElementById('hh-sticky-bar');
            var label   = document.getElementById('hh-bar-summary');
            var barBtn  = bar ? bar.querySelector('button') : null;

            /* clicking the floating bar button submits the main form */
            if (barBtn &amp;&amp; form) {
                barBtn.addEventListener('click', function () { form.submit(); });
            }

            function refresh() {
                var lines = 0, total = 0;
                inputs.forEach(function (inp) {
                    var v   = parseFloat(inp.value) || 0;
                    var row = inp.closest('tr');
                    if (v > 0) {
                        lines++;
                        total += v;
                        if (row) row.classList.add('hh-row-filled');
                    } else {
                        if (row) row.classList.remove('hh-row-filled');
                    }
                });
                if (lines > 0) {
                    bar.classList.remove('d-none');
                    document.body.classList.add('has-hh-bar');
                    label.textContent = lines + ' 款產品 · 合共 ' + total + ' 件';
                } else {
                    bar.classList.add('d-none');
                    document.body.classList.remove('has-hh-bar');
                }
            }
            inputs.forEach(function (inp) { inp.addEventListener('input', refresh); });
            refresh();
        })();
        </script>
    </template>


    <!--
    ================================================================
    /my/upload-sales
    ================================================================
    -->
    <template id="portal_upload_sales" name="Portal Upload Sales (上載購物紀錄)">
        <t t-call="portal.portal_layout">
            <t t-set="title">上載購物紀錄</t>
            <div class="container my-4">

                <div class="hh-page-title">
                    <span class="accent"/>
                    <h5 class="mb-0 fw-bold me-2">上載購物紀錄</h5>
                    <span class="text-muted small">Upload Purchase Records</span>
                </div>

                <t t-if="error">
                    <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
                        <i class="fa fa-exclamation-triangle"/>
                        <span>
                            <t t-if="error == 'no-date'">請選擇日期 / Please pick a date.</t>
                            <t t-if="error == 'no-qty'">請最少填寫一項數量 / Please enter at least one quantity.</t>
                            <t t-if="error == 'submit-failed'">提交失敗，請聯絡管理員 / Submission failed — please contact your manager.</t>
                        </span>
                    </div>
                </t>

                <form id="hh-order-form" action="/my/upload-sales/submit" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="hh-date-card">
                        <label class="fw-semibold mb-0 me-1">
                            <i class="fa fa-calendar-o me-1 text-muted"/>
                            訂單日期 / Order Date
                        </label>
                        <input type="date" name="date_order" class="form-control form-control-sm"
                               style="max-width:180px" required="required"/>
                    </div>

                    <t t-call="hh_portal_orders.hh_portal_order_form_body"/>

                    <div class="d-flex justify-content-between mt-4 mb-2">
                        <a href="/my" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-arrow-left me-1"/> 取消
                        </a>
                        <button t-if="grouped_products" type="submit" class="btn btn-primary px-4">
                            提交 Submit
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>


    <!--
    ================================================================
    /my/upload-sales/done — no prices shown
    ================================================================
    -->
    <template id="portal_upload_sales_done" name="Portal Upload Sales Done">
        <t t-call="portal.portal_layout">
            <t t-set="title">上載成功</t>
            <div class="container my-5">

                <div class="text-center mb-4">
                    <i class="fa fa-check-circle fa-3x" style="color:#198754"/>
                    <h5 class="mt-3 fw-bold">上載成功 / Submitted</h5>
                    <div class="mt-2">
                        <span class="hh-order-badge"><t t-esc="so.name"/></span>
                    </div>
                </div>

                <div class="card mx-auto" style="max-width:620px">
                    <div class="card-header small fw-semibold text-muted">
                        訂單明細 Order Summary
                        <span class="float-end"><t t-esc="len(so.order_line)"/> 款產品</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 hh-summary-table">
                            <thead>
                                <tr>
                                    <th>產品代碼</th>
                                    <th>產品名稱</th>
                                    <th class="text-end">數量</th>
                                    <th>單位</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="so.order_line" t-as="line">
                                    <t t-if="not line.display_type">
                                        <tr>
                                            <td class="small text-monospace">
                                                <t t-esc="line.product_id.default_code or ''"/>
                                            </td>
                                            <td><t t-esc="line.product_id.name"/></td>
                                            <td class="text-end fw-semibold">
                                                <t t-esc="'%g' % line.product_uom_qty"/>
                                            </td>
                                            <td class="text-muted small">
                                                <t t-esc="line.product_uom.name"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="text-center mt-4 d-flex justify-content-center gap-3">
                    <a href="/my/upload-sales" class="btn btn-outline-primary btn-sm">
                        <i class="fa fa-upload me-1"/> 再上載
                    </a>
                    <a href="/my" class="btn btn-outline-secondary btn-sm">
                        <i class="fa fa-home me-1"/> 返回主頁
                    </a>
                </div>

            </div>
        </t>
    </template>


    <!--
    ================================================================
    /my/place-order
    ================================================================
    -->
    <template id="portal_place_order" name="Portal Place Order (訂貨單)">
        <t t-call="portal.portal_layout">
            <t t-set="title" t-value="page_title"/>
            <div class="container my-4">

                <div class="hh-page-title">
                    <span class="accent"/>
                    <h5 class="mb-0 fw-bold"><t t-esc="page_title"/></h5>
                </div>

                <t t-if="error">
                    <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
                        <i class="fa fa-exclamation-triangle"/>
                        <span>
                            <t t-if="error == 'no-date'">請選擇送貨日期 / Please pick a delivery date.</t>
                            <t t-if="error == 'date-too-soon'">送貨日期必須為明日或之後 / Delivery date must be tomorrow or later.</t>
                            <t t-if="error == 'no-qty'">請最少填寫一項數量 / Please enter at least one quantity.</t>
                            <t t-if="error == 'submit-failed'">提交失敗，請聯絡管理員 / Submission failed — please contact your manager.</t>
                        </span>
                    </div>
                </t>

                <form id="hh-order-form" action="/my/place-order/submit" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="hh-date-card">
                        <label class="fw-semibold mb-0 me-1">
                            <i class="fa fa-truck me-1 text-muted"/>
                            送貨日期 / Delivery Date
                        </label>
                        <input type="date" name="commitment_date" class="form-control form-control-sm"
                               style="max-width:180px"
                               t-att-min="min_date" t-att-value="min_date"
                               required="required"/>
                        <span class="text-muted small">最早為明日 / Earliest: tomorrow</span>
                    </div>

                    <t t-call="hh_portal_orders.hh_portal_order_form_body"/>

                    <div class="d-flex justify-content-between mt-4 mb-2">
                        <a href="/my" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-arrow-left me-1"/> 取消
                        </a>
                        <button t-if="grouped_products" type="submit" class="btn btn-primary px-4">
                            提交 Submit
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>


