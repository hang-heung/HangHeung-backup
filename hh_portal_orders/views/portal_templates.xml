<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    ================================================================
    Global styles used by all HH portal pages.
    ================================================================
    -->
    <template id="hh_portal_order_table_style" name="HH Portal Styles">
        <style>
            /* ── Sticky table header (clears Odoo fixed navbar ~62px) ── */
            .hh-order-table thead th {
                position: sticky;
                top: 62px;
                background: #f8f9fa;
                z-index: 5;
                border-bottom: 2px solid #dee2e6;
            }

            /* ── Row highlight when qty filled ── */
            .hh-order-table tr.hh-row-filled {
                background-color: #fffbe6 !important;
            }
            .hh-order-table tr.hh-row-filled td { border-color: #ffe58f; }

            /* ── Category divider rows ── */
            .hh-cat-row td {
                background-color: #4a1728 !important;
                color: #fff !important;
                font-weight: 600;
                font-size: .82rem;
                letter-spacing: .05em;
                padding: .4rem .75rem !important;
            }
            .hh-cat-row .badge {
                background-color: rgba(255,255,255,.22) !important;
                color: #fff;
                font-family: monospace;
            }
            /* suppress mobile ::before on category rows */
            .hh-cat-row td::before { content: none !important; }

            /* ── Floating submit bar ── */
            .hh-sticky-bar {
                position: fixed;
                bottom: 0; left: 0; right: 0;
                z-index: 1040;
                background: #4a1728;
                color: #fff;
                box-shadow: 0 -2px 12px rgba(0,0,0,.25);
                padding: .55rem 0;
            }
            .hh-sticky-bar .btn-submit-bar {
                background: #fff;
                color: #4a1728;
                font-weight: 700;
                border: none;
                padding: .3rem 1.4rem;
                border-radius: 4px;
            }
            .hh-sticky-bar .btn-submit-bar:hover { background: #f0e6e8; }
            /* pad page bottom so last rows aren't hidden */
            body.has-hh-bar { padding-bottom: 58px; }

            /* ── Action tiles on portal home ── */
            .hh-action-tile {
                border-left: 4px solid #4a1728;
                transition: box-shadow .15s ease;
            }
            .hh-action-tile:hover { box-shadow: 0 4px 18px rgba(0,0,0,.11); }
            .hh-action-tile .tile-icon {
                font-size: 1.8rem;
                color: #4a1728;
                opacity: .65;
                min-width: 2.2rem;
                text-align: center;
            }

            /* ── Order list badges ── */
            .badge-hh-active  { background-color: #0d6efd; color: #fff; }
            .badge-hh-done    { background-color: #198754; color: #fff; }
            .badge-hh-cancel  { background-color: #6c757d; color: #fff; }

            /* ── Success page ── */
            .hh-order-badge {
                display: inline-block;
                background: #4a1728;
                color: #fff;
                border-radius: 6px;
                padding: .3rem 1rem;
                font-size: 1.15rem;
                font-weight: 700;
                letter-spacing: .04em;
            }
            .hh-summary-table th {
                background: #f8f9fa;
                font-size: .82rem;
                font-weight: 600;
            }
            .hh-summary-table td { font-size: .9rem; }

            /* ── Page title accent bar ── */
            .hh-page-title {
                display: flex;
                align-items: center;
                margin-bottom: 1.25rem;
                padding-bottom: .75rem;
                border-bottom: 1px solid #dee2e6;
            }
            .hh-page-title .accent {
                width: 4px; height: 1.8rem;
                background: #4a1728;
                border-radius: 2px;
                margin-right: .75rem;
                flex-shrink: 0;
            }

            /* ── Date card ── */
            .hh-date-card {
                background: #fafafa;
                border: 1px solid #e9ecef;
                border-radius: 6px;
                padding: .75rem 1rem;
                margin-bottom: 1.25rem;
                display: flex;
                align-items: center;
                gap: 1rem;
                flex-wrap: wrap;
            }

            /* ── Mobile ── */
            @media (max-width: 767.98px) {
                .hh-order-table thead { display: none; }
                .hh-order-table,
                .hh-order-table tbody,
                .hh-order-table tr,
                .hh-order-table td { display: block; width: 100%; }
                .hh-order-table tr {
                    margin-bottom: .85rem;
                    border: 1px solid #dee2e6;
                    border-radius: .4rem;
                    overflow: hidden;
                }
                .hh-order-table td {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: .75rem;
                    border: 0;
                    border-bottom: 1px solid #f1f1f1;
                    text-align: right;
                    padding: .45rem .75rem;
                }
                .hh-order-table tr td:last-child { border-bottom: 0; }
                .hh-order-table td::before {
                    content: attr(data-label);
                    font-weight: 600;
                    color: #6c757d;
                    text-align: left;
                    flex: 0 0 40%;
                }
                .hh-order-table td > .form-control,
                .hh-order-table td > .form-select { flex: 1 1 auto; min-width: 0; }
                .hh-sticky-bar .container { flex-wrap: wrap; gap: .35rem; }
            }
        </style>
    </template>


    <!--
    ================================================================
    Portal home: action tiles.
    ================================================================
    -->
    <template id="portal_my_home_hh"
              inherit_id="portal.portal_my_home"
              name="HH Portal Order Home Tiles"
              priority="30">
