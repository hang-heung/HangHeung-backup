    <!--
    ================================================================
    No access page
    ================================================================
    -->
    <template id="portal_no_access" name="Portal No Access">
        <t t-call="portal.portal_layout">
            <t t-set="title">Access Not Configured</t>
            <div class="container my-5 text-center py-5">
                <i class="fa fa-lock fa-3x text-muted mb-3"/>
                <h5 class="fw-bold mt-2">尚未開通 / Access not configured</h5>
                <p class="text-muted mt-2">
                    請聯絡恆香為您開通此功能。<br/>
                    Please contact HangHeung to set up your portal access.
                </p>
                <a href="/my" class="btn btn-outline-secondary btn-sm mt-3">
                    <i class="fa fa-arrow-left me-1"/> 返回 Back
                </a>
            </div>
        </t>
    </template>


    <!--
    ================================================================
    Hide ALL pricing on the portal Sale Order detail page.
    ================================================================
    -->
    <template id="hh_hide_sale_portal_prices"
              inherit_id="sale.sale_order_portal_content"
              name="HH: hide prices on portal sales orders">
        <xpath expr="//table[@id='sales_order_table']" position="before">
            <style>
                #sales_order_table th:nth-child(n+3),
                #sales_order_table td:nth-child(n+3),
                #sales_order_table tr.is-subtotal,
                table[name="sale_order_totals_table"],
                div#total[name="total"],
                [data-id="total_amount"],
                [data-id="total_untaxed"],
                [data-id="amount_undiscounted"],
                [name="sale_order_advantage"],
                .o_portal_order_price,
                .oe_subtotal_footer { display: none !important; }
            </style>
        </xpath>
    </template>


    <!--
    ================================================================
    Hide ALL pricing on the portal Purchase Order detail page.
    ================================================================
    -->
    <template id="hh_hide_purchase_portal_prices"
              inherit_id="purchase.purchase_order_portal_content"
              name="HH: hide prices on portal purchase orders">
        <xpath expr="//table[@id='purchase_order_table']" position="before">
            <style>
                #purchase_order_table th:nth-child(n+3),
                #purchase_order_table td:nth-child(n+3),
                #purchase_order_table tr.is-subtotal,
                div#total[name="total"],
                [data-id="total_amount"],
                .oe_subtotal_footer { display: none !important; }
            </style>
        </xpath>
    </template>


    <!--
    ================================================================
    Improved 銷售訂單 list: status badge, delivery date, line count.
    No Total column.
    ================================================================
    -->
    <template id="hh_hide_sale_list_total"
              inherit_id="sale.portal_my_orders"
              name="HH: improved portal sales order list">
        <!-- Replace header row -->
        <xpath expr="//thead/tr" position="replace">
            <tr class="active">
                <th>銷售訂單 #</th>
                <th>訂單日期</th>
                <th class="d-none d-md-table-cell">送貨日期</th>
                <th class="text-center d-none d-md-table-cell">產品數</th>
                <th class="text-center">狀態</th>
            </tr>
        </xpath>
        <!-- Replace order rows -->
        <xpath expr="//t[@t-foreach='orders']" position="replace">
            <t t-foreach="orders" t-as="order">
                <tr>
                    <td>
                        <a t-att-href="order.get_portal_url()" class="fw-semibold text-decoration-none">
                            <t t-out="order.name"/>
                        </a>
                    </td>
                    <td>
                        <span t-field="order.date_order" t-options="{'widget': 'date'}"/>
                    </td>
                    <td class="d-none d-md-table-cell text-muted">
                        <span t-if="order.commitment_date"
                              t-field="order.commitment_date"
                              t-options="{'widget': 'date'}"/>
                        <span t-else="">—</span>
                    </td>
                    <td class="text-center d-none d-md-table-cell text-muted small">
                        <t t-esc="len(order.order_line)"/>
                    </td>
                    <td class="text-center">
                        <span t-if="order.state == 'sale'"
                              class="badge badge-hh-active">進行中</span>
                        <span t-elif="order.state == 'done'"
                              class="badge badge-hh-done">已完成</span>
                        <span t-elif="order.state == 'cancel'"
                              class="badge badge-hh-cancel">已取消</span>
                        <span t-else="" class="badge bg-light text-dark">
                            <t t-esc="order.state"/>
                        </span>
                    </td>
                </tr>
            </t>
        </xpath>
    </template>


    <!--
    ================================================================
    Hide Total column in portal Purchase Orders list (補貨紀錄).
    ================================================================
    -->
    <template id="hh_hide_purchase_list_total"
              inherit_id="purchase.portal_my_purchase_orders"
              name="HH: hide Total column in portal purchase order list">
        <xpath expr="//th[@id='order_total_header']" position="replace"/>
        <xpath expr="//td[@id='order_total']" position="replace"/>
    </template>


    <!--
    ================================================================
    Footer cleanup: static company name + remove Powered-by-Odoo.
    Language selector is deactivated separately (portal view).
    ================================================================
    -->
    <template id="hh_footer_cleanup"
              inherit_id="web.frontend_layout"
              name="HH: footer company name + remove brand promotion">
        <xpath expr="//span[hasclass('o_footer_copyright_name')]" position="replace">
            <span class="o_footer_copyright_name me-2">版權所有 © Hang Heung Cake Shop Ltd</span>
        </xpath>
        <xpath expr="//t[@t-call='web.brand_promotion']" position="replace"/>
    </template>

</odoo>
