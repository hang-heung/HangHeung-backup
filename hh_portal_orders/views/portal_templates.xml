                <div class="text-center mt-4 d-flex justify-content-center gap-3">
                    <a href="/my/place-order" class="btn btn-outline-primary btn-sm">
                        <i class="fa fa-shopping-basket me-1"/> 再訂貨
                    </a>
                    <a href="/my" class="btn btn-outline-secondary btn-sm">
                        <i class="fa fa-home me-1"/> 返回主頁
                    </a>
                </div>

            </div>
        </t>
