<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_portal_order_control_tree" model="ir.ui.view">
        <field name="name">portal.order.control.list</field>
        <field name="model">portal.order.control</field>
        <field name="arch" type="xml">
            <list string="Portal Order Control">
                <field name="partner_id"/>
                <field name="warehouse_id"/>
                <field name="pricelist_id"/>
                <field name="product_count" string="# Products"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_portal_order_control_form" model="ir.ui.view">
        <field name="name">portal.order.control.form</field>
        <field name="model">portal.order.control</field>
        <field name="arch" type="xml">
            <form string="Portal Order Control">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="partner_id" string="Portal Customer"/>
                        <h1>
                            <field name="partner_id"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="pricelist_id" options="{'no_quick_create': True}"/>
                            <field name="warehouse_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="product_count" string="# Allowed Products"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Allowed Products" name="products">
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"
                                   placeholder="輸入舊貨號 / Type Old Item Code to add..."/>
                        </page>
                        <page string="Internal Note" name="note">
                            <field name="note" nolabel="1" placeholder="Notes for the sales team..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_portal_order_control_search" model="ir.ui.view">
        <field name="name">portal.order.control.search</field>
        <field name="model">portal.order.control</field>
        <field name="arch" type="xml">
            <search string="Portal Order Control">
                <field name="partner_id"/>
                <field name="pricelist_id"/>
                <field name="product_ids" string="Product"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group string="Group By">
                    <filter name="group_pricelist" string="Pricelist" context="{'group_by': 'pricelist_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_portal_order_control" model="ir.actions.act_window">
        <field name="name">Portal Order Control</field>
        <field name="res_model">portal.order.control</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_portal_order_control_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set up portal access for a customer
            </p>
            <p>
                For each portal customer (consignee), pick the pricelist
                their portal orders should use and the products they're
                allowed to order.
            </p>
        </field>
    </record>

    <menuitem id="menu_portal_order_control"
              name="Portal Order Control"
              parent="sale.menu_sale_config"
              action="action_portal_order_control"
              sequence="50"/>

</odoo>
